<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_nav_graph"
    app:startDestination="@id/homeFragment">

    <argument
        android:name="username"
        app:argType="string"
        android:defaultValue="" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.androidapp.ui.home.HomeFragment"
        android:label="Home">

        <argument
            android:name="username"
            app:argType="string"
            android:defaultValue="" />

        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/activityDetailFragment" />

        <action
            android:id="@+id/action_home_to_search"
            app:destination="@id/searchFragment" />

        <action
            android:id="@+id/action_home_to_profile"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.androidapp.ui.home.SearchFragment"
        android:label="Buscar">

        <action
            android:id="@+id/action_search_to_detail"
            app:destination="@id/activityDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/activityDetailFragment"
        android:name="com.example.androidapp.ui.home.ActivityDetailFragment"
        android:label="Detalle">

        <argument
            android:name="activityId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <!-- fragmentos de perfil, accion desde home a profile y de profile a editProfile -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.androidapp.ui.home.ProfileFragment"
        android:label="Perfil">

        <action
            android:id="@+id/action_profile_to_editProfile"
            app:destination="@id/editProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.example.androidapp.ui.home.EditProfileFragment"
        android:label="EditarPerfil">

        <action
            android:id="@+id/action_editProfile_to_profile"
            app:destination="@+id/profileFragment"
            app:popUpTo="@id/profileFragment"
            app:popUpToInclusive="true"/>

    </fragment>

</navigation>

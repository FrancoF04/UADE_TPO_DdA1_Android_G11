<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_nav_graph"
    app:startDestination="@id/homeFragment">

    <argument
        android:name="username"
        app:argType="string"
        android:defaultValue="" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.androidapp.ui.home.HomeFragment"
        android:label="Home">

        <argument
            android:name="username"
            app:argType="string"
            android:defaultValue="" />

        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/activityDetailFragment" />

        <action
            android:id="@+id/action_home_to_search"
            app:destination="@id/searchFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.androidapp.ui.home.SearchFragment"
        android:label="Buscar">

        <action
            android:id="@+id/action_search_to_detail"
            app:destination="@id/activityDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/activityDetailFragment"
        android:name="com.example.androidapp.ui.home.ActivityDetailFragment"
        android:label="Detalle">

        <argument
            android:name="activityId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

</navigation>
